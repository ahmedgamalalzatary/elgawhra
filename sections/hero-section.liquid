{% comment %}
  Hero Section - Elgawhra
  Premium warm-toned hero with split layout, decorative elements, and entrance animations
{% endcomment %}

<style>
  .hero-section {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: linear-gradient(145deg, #65443E 0%, #553830 35%, #4a302b 65%, #3d2520 100%);
  }

  .hero-section--small { min-height: 500px; }
  .hero-section--medium { min-height: 650px; }
  .hero-section--large { min-height: 85vh; }
  .hero-section--full { min-height: 100vh; }

  /* --- Background layers --- */
  .hero__texture {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    z-index: 1;
    pointer-events: none;
  }

  .hero__glow {
    position: absolute;
    pointer-events: none;
    z-index: 1;
    border-radius: 50%;
  }

  .hero__glow--primary {
    width: 65%;
    height: 130%;
    right: -15%;
    top: -15%;
    background: radial-gradient(ellipse at center, rgba(247, 208, 176, 0.1), transparent 65%);
  }

  .hero__glow--secondary {
    width: 35%;
    height: 35%;
    left: 8%;
    bottom: -10%;
    background: radial-gradient(ellipse at center, rgba(247, 208, 176, 0.05), transparent 65%);
  }

  /* --- Decorative orbs --- */
  .hero__orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
  }

  .hero__orb--1 {
    width: 220px;
    height: 220px;
    border: 1px solid rgba(247, 208, 176, 0.08);
    top: 8%;
    right: 12%;
    animation: heroFloat 10s ease-in-out infinite;
  }

  .hero__orb--2 {
    width: 90px;
    height: 90px;
    background: rgba(247, 208, 176, 0.04);
    bottom: 12%;
    left: 4%;
    animation: heroFloat 8s ease-in-out infinite reverse;
  }

  .hero__orb--3 {
    width: 140px;
    height: 140px;
    border: 1px solid rgba(247, 208, 176, 0.05);
    bottom: 20%;
    right: 3%;
    animation: heroFloat 12s ease-in-out infinite 2s;
  }

  /* --- Layout --- */
  .hero__wrapper {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    padding: 6rem 0;
    width: 100%;
  }

  /* --- Text content --- */
  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.7rem 1.8rem;
    border: 1px solid rgba(247, 208, 176, 0.25);
    border-radius: 4rem;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #F7D0B0;
    width: fit-content;
    background: rgba(247, 208, 176, 0.04);
  }

  .hero__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #F7D0B0;
    animation: heroPulse 2s ease-in-out infinite;
  }

  /* Heading */
  .hero__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(3.6rem, 5.5vw, 7rem);
    font-weight: 800;
    line-height: 1.06;
    color: #ffffff;
    margin: 0;
    letter-spacing: -0.015em;
  }

  .hero__highlight {
    color: #F7D0B0;
    position: relative;
    display: inline-block;
  }

  .hero__highlight::after {
    content: '';
    position: absolute;
    bottom: 0.04em;
    left: -0.06em;
    right: -0.06em;
    height: 0.22em;
    background: rgba(247, 208, 176, 0.1);
    border-radius: 0.08em;
    z-index: -1;
  }

  /* Subheading */
  .hero__subheading {
    font-size: clamp(1.45rem, 1.6vw, 1.85rem);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.65);
    max-width: 460px;
    margin: 0;
    font-weight: 400;
  }

  .hero__subheading p { margin: 0; }

  /* Buttons */
  .hero__actions {
    display: flex;
    gap: 1.4rem;
    flex-wrap: wrap;
    margin-top: 0.8rem;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 3.4rem;
    font-size: 1.3rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    cursor: pointer;
    border-radius: 0;
    font-family: var(--font-body-family);
  }

  .hero__btn--primary {
    background: #F7D0B0;
    color: #3d2520;
    border: 2px solid #F7D0B0;
  }

  .hero__btn--primary:hover {
    background: #ffffff;
    border-color: #ffffff;
    color: #3d2520;
    transform: translateY(-3px);
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.25);
  }

  .hero__btn--secondary {
    background: transparent;
    color: #ffffff;
    border: 2px solid rgba(255, 255, 255, 0.35);
  }

  .hero__btn--secondary:hover {
    border-color: #ffffff;
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-3px);
  }

  /* --- Media / Image area --- */
  .hero__media {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__media-shape {
    position: absolute;
    inset: -16px;
    border-radius: 1.8rem;
    border: 1px solid rgba(247, 208, 176, 0.12);
    transform: rotate(3deg);
    pointer-events: none;
  }

  .hero__media-shape--2 {
    inset: -32px;
    border-color: rgba(247, 208, 176, 0.05);
    transform: rotate(-2deg);
    border-radius: 2.2rem;
  }

  .hero__media-inner {
    position: relative;
    border-radius: 1.4rem;
    overflow: hidden;
    box-shadow:
      0 30px 60px -15px rgba(0, 0, 0, 0.35),
      0 0 0 1px rgba(247, 208, 176, 0.08);
    width: 100%;
    aspect-ratio: 4 / 5;
  }

  .hero__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .hero__media-inner:hover .hero__image {
    transform: scale(1.04);
  }

  .hero__media-inner::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(61, 37, 32, 0.25), transparent 50%);
    pointer-events: none;
    border-radius: 1.4rem;
  }

  /* Floating tag on image */
  .hero__tag {
    position: absolute;
    bottom: -1.2rem;
    right: -1.2rem;
    background: #F7D0B0;
    color: #3d2520;
    padding: 1rem 2rem;
    border-radius: 0.8rem;
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.2);
    z-index: 3;
    white-space: nowrap;
  }

  [dir="rtl"] .hero__tag {
    right: auto;
    left: -1.2rem;
  }

  /* Placeholder when no image */
  .hero__media-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 1.4rem;
    background: rgba(247, 208, 176, 0.06);
    border: 2px dashed rgba(247, 208, 176, 0.15);
  }

  .hero__media-placeholder svg {
    width: 48px;
    height: 48px;
    opacity: 0.25;
    color: #F7D0B0;
  }

  /* --- Scroll indicator --- */
  .hero__scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    z-index: 3;
  }

  .hero__scroll-text {
    font-size: 1rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    font-weight: 500;
  }

  .hero__scroll-line {
    width: 1px;
    height: 32px;
    position: relative;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.08);
  }

  .hero__scroll-line::after {
    content: '';
    position: absolute;
    top: -100%;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent, #F7D0B0);
    animation: heroScrollLine 2s ease-in-out infinite;
  }

  /* ==============================
     Entrance Animations
     ============================== */
  .hero__badge {
    opacity: 0;
    transform: translateY(25px);
    animation: heroFadeUp 0.7s ease forwards 0.15s;
  }
  .hero__heading {
    opacity: 0;
    transform: translateY(25px);
    animation: heroFadeUp 0.8s ease forwards 0.3s;
  }
  .hero__subheading {
    opacity: 0;
    transform: translateY(25px);
    animation: heroFadeUp 0.7s ease forwards 0.45s;
  }
  .hero__actions {
    opacity: 0;
    transform: translateY(25px);
    animation: heroFadeUp 0.7s ease forwards 0.6s;
  }
  .hero__media {
    opacity: 0;
    transform: scale(0.94);
    animation: heroScaleUp 1s ease forwards 0.35s;
  }
  .hero__scroll {
    opacity: 0;
    animation: heroFadeIn 0.8s ease forwards 1.2s;
  }

  /* ==============================
     Keyframes
     ============================== */
  @keyframes heroFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroFadeIn {
    to { opacity: 1; }
  }

  @keyframes heroScaleUp {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes heroFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-18px); }
  }

  @keyframes heroPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  @keyframes heroScrollLine {
    0% { top: -100%; }
    100% { top: 100%; }
  }

  /* ==============================
     Reduced Motion
     ============================== */
  @media (prefers-reduced-motion: reduce) {
    .hero__badge,
    .hero__heading,
    .hero__subheading,
    .hero__actions,
    .hero__media,
    .hero__scroll {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }

    .hero__orb,
    .hero__badge-dot,
    .hero__scroll-line::after {
      animation: none !important;
    }

    .hero__image {
      transition: none;
    }
  }

  /* ==============================
     Responsive
     ============================== */
  @media screen and (max-width: 989px) {
    .hero__wrapper {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3.5rem;
      padding: 4rem 0;
    }

    .hero__content {
      align-items: center;
      order: 2;
    }

    .hero__media {
      order: 1;
      max-width: 380px;
      margin: 0 auto;
      width: 100%;
    }

    .hero__subheading {
      margin-left: auto;
      margin-right: auto;
    }

    .hero__actions {
      justify-content: center;
    }

    .hero-section--large,
    .hero-section--full {
      min-height: auto;
    }

    .hero__orb--1 { width: 140px; height: 140px; }
    .hero__orb--3 { display: none; }
  }

  @media screen and (max-width: 749px) {
    .hero-section {
      min-height: auto !important;
    }

    .hero__wrapper {
      padding: 3rem 0 4rem;
      gap: 2.5rem;
    }

    .hero__content {
      gap: 1.5rem;
    }

    .hero__media {
      max-width: 300px;
    }

    .hero__media-shape { display: none; }
    .hero__orb { display: none; }
    .hero__scroll { display: none; }

    .hero__tag {
      bottom: -0.8rem;
      right: -0.5rem;
      padding: 0.7rem 1.4rem;
      font-size: 1rem;
    }

    .hero__btn {
      padding: 1.3rem 2.6rem;
      font-size: 1.2rem;
      width: 100%;
    }

    .hero__actions {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
    }
  }
</style>

<section class="hero-section hero-section--{{ section.settings.min_height }}">
  {%- comment -%} Background layers {%- endcomment -%}
  <div class="hero__texture"></div>
  <div class="hero__glow hero__glow--primary"></div>
  <div class="hero__glow hero__glow--secondary"></div>

  {%- comment -%} Decorative orbs {%- endcomment -%}
  <div class="hero__orb hero__orb--1"></div>
  <div class="hero__orb hero__orb--2"></div>
  <div class="hero__orb hero__orb--3"></div>

  <div class="hero__wrapper page-width">
    {%- comment -%} --- Text column --- {%- endcomment -%}
    <div class="hero__content">
      {%- if section.settings.badge_text != blank -%}
        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          {{ section.settings.badge_text }}
        </div>
      {%- endif -%}

      <h1 class="hero__heading">
        {%- if section.settings.heading_highlight != blank -%}
          {%- assign heading_parts = section.settings.heading | split: section.settings.heading_highlight -%}
          {%- if heading_parts.size > 1 -%}
            {{ heading_parts.first }}<span class="hero__highlight">{{ section.settings.heading_highlight }}</span>{{ heading_parts.last }}
          {%- else -%}
            {{ section.settings.heading | escape }}
          {%- endif -%}
        {%- else -%}
          {{ section.settings.heading | escape }}
        {%- endif -%}
      </h1>

      {%- if section.settings.subheading != blank -%}
        <div class="hero__subheading rte">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label_1 != blank or section.settings.button_label_2 != blank -%}
        <div class="hero__actions">
          {%- if section.settings.button_label_1 != blank -%}
            <a
              href="{{ section.settings.button_link_1 | default: '#' }}"
              class="hero__btn hero__btn--primary"
            >
              {{ section.settings.button_label_1 | escape }}
            </a>
          {%- endif -%}

          {%- if section.settings.button_label_2 != blank -%}
            <a
              href="{{ section.settings.button_link_2 | default: '#' }}"
              class="hero__btn hero__btn--secondary"
            >
              {{ section.settings.button_label_2 | escape }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} --- Image column --- {%- endcomment -%}
    <div class="hero__media">
      <div class="hero__media-shape"></div>
      <div class="hero__media-shape hero__media-shape--2"></div>

      {%- if section.settings.image != blank -%}
        <div class="hero__media-inner">
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              widths: '375, 550, 750, 1000, 1200',
              sizes: '(min-width: 990px) 42vw, (min-width: 750px) 50vw, 80vw',
              class: 'hero__image',
              alt: section.settings.image.alt | default: section.settings.heading
          }}
        </div>
      {%- else -%}
        <div class="hero__media-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
          </svg>
        </div>
      {%- endif -%}

      {%- if section.settings.image_tag_text != blank -%}
        <div class="hero__tag">{{ section.settings.image_tag_text }}</div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Scroll indicator {%- endcomment -%}
  {%- if section.settings.show_scroll_indicator -%}
    <div class="hero__scroll">
      <span class="hero__scroll-text">Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero Section",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Premium Quality",
      "info": "Small label above the heading. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover The Finest Flavors"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Highlight word",
      "default": "Finest",
      "info": "This word in the heading will be styled with the accent color."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Premium coffee, chocolate, nuts & snacks crafted with passion and delivered fresh to your door.</p>"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary button label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "image_tag_text",
      "label": "Image tag text",
      "default": "100% Natural",
      "info": "Small floating label on the image corner. Leave blank to hide."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "min_height",
      "label": "Section height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full", "label": "Full screen" }
      ],
      "default": "large"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}
